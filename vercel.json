{
  "version": 2,
  "builds": [
    {
      "src": "backend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/pages/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "frontend/pages/$1"
    },
    {
      "src": "/(.*)\\.html",
      "dest": "frontend/$1.html"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    }
  ]
}
